# ============================================================
# Dynamic Chat Layer - Environment Variables
# Copy this file to .env (or set in your hosting panel) and fill in your values.
# DO NOT commit real secrets to git.
# ============================================================

# --- Core ---
NODE_ENV=production

# PostgreSQL connection string (required)
# Your ScalaHosting DB example:
# DATABASE_URL=postgresql://60wattsofclaritycom_jason:YOUR_PASSWORD_HERE@165.140.156.47:6543/60wattsofclaritycom_website
DATABASE_URL=postgresql://user:password@host:port/database_name

# --- Clerk Authentication (required) ---
CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key_here

# --- Google Gemini AI (image generation) ---
AI_INTEGRATIONS_GEMINI_API_KEY=your_gemini_api_key_here
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# For Google Cloud Storage on self-hosted servers, set:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json

# --- Object Storage Paths (GCS) ---
# Update these to match your buckets. Note: current implementation has
# some Replit-specific code in objectStorage.ts that may need adjustment
# for full self-hosting (standard GCS signed URLs).
PUBLIC_OBJECT_SEARCH_PATHS=your-bucket-name/public
PRIVATE_OBJECT_DIR=your-bucket-name/private

# --- Optional: External Launch Lemonade Chat Endpoint ---
LAUNCH_LEMONADE_ENDPOINT=https://sip.launchlemonade.app/version-live/api/1.1/wf
LAUNCH_LEMONADE_API_KEY=your_launch_lemonade_api_key
LAUNCH_LEMONADE_ID=your_assistant_id

# --- Logging ---
LOG_LEVEL=info

# --- Frontend Vite (optional for production builds) ---
# BASE_PATH=/
